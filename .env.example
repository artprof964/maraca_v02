# Local backend service defaults.
#
# Copy to `.env` before starting local services:
#   Copy-Item .env.example .env

# Optional LLM adapter settings.
# `DEEPSEEK_API_KEY` is accepted as a backward-compatible alias, but
# `deepseek-open-art` is the standard key used by this project.
deepseek-open-art=
LLM_API_URL=https://api.deepseek.com
LLM_PRIMARY_MODEL=deepseek-v4-pro
LLM_FALLBACK_MODEL=provider-fallback-model
LLM_CLASSIFIER_MODEL=provider-classifier-model
LLM_EMBEDDING_MODEL=provider-embedding-model

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=evidence_chunks

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdevpassword
NEO4J_DATABASE=neo4j

RAG_STORAGE_ROOT=.local/storage
RAG_MODEL_PROFILE=local-dev
